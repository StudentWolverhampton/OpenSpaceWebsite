<section id="showcase" class="relative border-b border-border px-6 py-24 sm:py-32">
  <div class="absolute inset-0 bg-grid opacity-30"></div>

  <div class="relative z-10 mx-auto max-w-7xl">
    <div class="reveal mx-auto mb-16 max-w-2xl text-center">
      <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.2em] text-cyber">Showcase</span>
      <h2 class="mb-4 text-3xl font-bold tracking-tight font-display sm:text-4xl md:text-5xl">
        See it in <span class="text-gradient">action</span>
      </h2>
      <p class="text-base leading-relaxed text-muted sm:text-lg">
        A clean, modern interface that puts your work front and center.
      </p>
    </div>

    <div class="flex justify-center gap-4" id="showcase-tabs">
      <button data-tab="workspace" class="tab-btn active rounded-xl border border-cyber/20 bg-cyber/10 px-5 py-2 font-mono text-xs text-cyber transition-all hover:bg-cyber/20">
        ~/workspace
      </button>
      <button data-tab="menu" class="tab-btn rounded-xl border border-border bg-white/5 px-5 py-2 font-mono text-xs text-muted transition-all hover:border-cyber/20 hover:text-cyber">
        ~/projects
      </button>
    </div>

    <div class="reveal-scale relative mt-8">
      <div class="mx-auto max-w-6xl">
        <div class="overflow-hidden rounded-2xl border border-border/50 bg-space-light shadow-2xl shadow-cyber/5">
          <div class="flex items-center gap-2 border-b border-border bg-space-light/50 px-5 py-3.5">
            <div class="h-3 w-3 rounded-full bg-red-500/40"></div>
            <div class="h-3 w-3 rounded-full bg-amber-500/40"></div>
            <div class="h-3 w-3 rounded-full bg-green-500/40"></div>
            <span class="ml-3 font-mono text-xs text-muted">OpenSpace — premium terminal</span>
          </div>
          <div class="relative overflow-hidden bg-[#0a0e1a]">
            <div id="tab-workspace" class="tab-content block">
              <img
                src="/images/workspace.png"
                alt="OpenSpace terminal workspace"
                class="w-full"
                loading="lazy"
              />
            </div>
            <div id="tab-menu" class="tab-content hidden">
              <img
                src="/images/menu.png"
                alt="OpenSpace project list"
                class="w-full"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => { entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }); },
    { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
  );
  document.querySelectorAll('.reveal, .reveal-scale').forEach((el) => observer.observe(el));

  document.querySelectorAll('.tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach((b) => {
        b.className = 'tab-btn rounded-xl border border-border bg-white/5 px-5 py-2 font-mono text-xs text-muted transition-all hover:border-cyber/20 hover:text-cyber';
      });
      btn.className = 'tab-btn active rounded-xl border border-cyber/20 bg-cyber/10 px-5 py-2 font-mono text-xs text-cyber transition-all hover:bg-cyber/20';
      document.querySelectorAll('.tab-content').forEach((c) => c.classList.add('hidden'));
      document.getElementById('tab-' + btn.dataset.tab).classList.remove('hidden');
    });
  });
</script>
