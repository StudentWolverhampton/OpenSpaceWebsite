<section class="relative flex min-h-screen items-center overflow-hidden pt-24">
  <!-- Warm ambient orbs -->
  <div class="orb top-[-15%] left-[-5%] h-[500px] w-[500px] bg-ember animate-drift-slow" style="opacity: 0.06;"></div>
  <div class="orb bottom-[-20%] right-[-10%] h-[600px] w-[600px] bg-ember-dark animate-drift-slow" style="animation-delay: -8s; opacity: 0.04;"></div>

  <!-- Subtle grid -->
  <div class="absolute inset-0 opacity-[0.015]" style="background-image: linear-gradient(rgba(245,158,11,0.2) 1px, transparent 1px), linear-gradient(90deg, rgba(245,158,11,0.2) 1px, transparent 1px); background-size: 64px 64px;"></div>

  <div class="relative z-10 mx-auto w-full max-w-7xl px-6">
    <div class="grid items-center gap-16 lg:grid-cols-12 lg:gap-12">
      <!-- Left content -->
      <div class="lg:col-span-5">
        <div class="reveal mb-8">
          <span class="inline-flex items-center gap-2 rounded-full border border-ember/15 bg-ember/5 px-4 py-1.5 text-sm text-ember">
            <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-ember"></span>
            Now available for Windows, Mac & Linux
          </span>
        </div>

        <h1 class="reveal mb-6 text-4xl font-light leading-[1.1] tracking-tight sm:text-5xl md:text-6xl lg:text-[3.8rem]">
          <span class="font-serif italic text-foreground">Your terminal,</span><br />
          <span class="text-ember-gradient font-sans font-semibold">reimagined.</span>
        </h1>

        <p class="reveal mb-10 max-w-md text-base leading-relaxed text-muted sm:text-lg">
          A premium workspace built for developers who live in the terminal. 
          Multiple shells, integrated browser, keyboard-first — all in one beautiful interface.
        </p>

        <div class="reveal flex flex-col gap-4 sm:flex-row sm:items-center">
          <a href="#download" class="btn-primary relative inline-flex items-center gap-2 rounded-lg px-7 py-3.5 text-base">
            <span class="flex items-center gap-2">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
              </svg>
              Download Free
              <span class="rounded-md bg-black/15 px-2 py-0.5 text-xs font-mono font-normal">v1.0</span>
            </span>
          </a>
          <a href="#features" class="btn-ghost inline-flex items-center gap-2 rounded-lg px-7 py-3.5 text-base text-foreground">
            Explore Features
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" />
            </svg>
          </a>
        </div>

        <div class="reveal mt-12 flex flex-wrap items-center gap-6 text-xs text-subtle">
          <span class="flex items-center gap-2">
            <svg class="h-4 w-4 text-ember/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
            Open-source
          </span>
          <span class="flex items-center gap-2">
            <svg class="h-4 w-4 text-ember/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            Real PTY
          </span>
          <span class="flex items-center gap-2">
            <svg class="h-4 w-4 text-ember/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 019.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.841m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 8.25V6.75a1.5 1.5 0 00-3 0v1.5m0 0v6a1.5 1.5 0 003 0v-1.5" /></svg>
            Cross-platform
          </span>
        </div>
      </div>

      <!-- Right: Terminal mockup -->
      <div class="reveal lg:col-span-7">
        <div class="animate-float">
          <div class="relative overflow-hidden rounded-2xl border border-border bg-surface/60 glow-amber-strong backdrop-blur-xl">
            <div class="flex items-center gap-3 border-b border-border px-5 py-3.5">
              <div class="flex gap-2">
                <span class="h-2.5 w-2.5 rounded-full bg-red-500/60"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-amber-500/60"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-green-500/60"></span>
              </div>
              <div class="flex-1 text-center">
                <span class="font-mono text-xs text-muted">OpenSpace — ~/workspace</span>
              </div>
            </div>

            <div class="p-6 font-mono text-sm leading-relaxed">
              <div class="mb-3"><span class="text-ember">❯</span> <span class="text-foreground">cd ~/projects</span></div>
              <div class="mb-3"><span class="text-ember">❯</span> <span class="text-foreground">npm run dev</span></div>
              <div class="mb-2 text-muted">
                <span class="text-green-500/80">✓</span> VITE v5.4.0 ready in <span class="text-ember-light">287ms</span>
              </div>
              <div class="mb-2">
                <span class="text-green-500/80">➜</span> <span class="text-muted">Local:</span> <span class="text-ember underline decoration-ember/30">http://localhost:5173/</span>
              </div>
              <div class="mb-4">
                <span class="text-green-500/80">➜</span> <span class="text-muted">Network:</span> <span class="text-subtle">use --host to expose</span>
              </div>

              <div class="mt-5 border-t border-border pt-5">
                <div class="mb-2 flex items-center gap-2">
                  <span class="rounded bg-ember/10 px-2 py-0.5 text-[10px] font-medium text-ember">shell</span>
                  <span class="text-subtle">bash</span>
                </div>
                <div>
                  <span class="text-ember">❯</span> <span class="inline-block w-2.5 animate-pulse bg-ember">&nbsp;</span>
                </div>
              </div>
            </div>
          </div>
          <div class="absolute -inset-4 -z-10 rounded-3xl bg-ember/5 blur-3xl"></div>
        </div>
      </div>
    </div>
  </div>
</section>
