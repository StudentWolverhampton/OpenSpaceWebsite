<section class="relative border-b border-border px-6 py-20">
  <div class="mx-auto max-w-5xl">
    <div class="grid grid-cols-2 gap-6 md:grid-cols-4">
      <div class="reveal text-center">
        <div class="mb-1 font-display text-3xl font-bold text-gradient sm:text-4xl">12+</div>
        <div class="text-xs text-muted sm:text-sm">Shortcuts</div>
      </div>
      <div class="reveal text-center">
        <div class="mb-1 font-display text-3xl font-bold text-gradient-amber sm:text-4xl">8</div>
        <div class="text-xs text-muted sm:text-sm">Max Terminals</div>
      </div>
      <div class="reveal text-center">
        <div class="mb-1 font-display text-3xl font-bold text-gradient sm:text-4xl">3</div>
        <div class="text-xs text-muted sm:text-sm">Terminal Types</div>
      </div>
      <div class="reveal text-center">
        <div class="mb-1 font-display text-3xl font-bold text-gradient-amber sm:text-4xl">Free</div>
        <div class="text-xs text-muted sm:text-sm">Open-Source</div>
      </div>
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => { entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }); },
    { threshold: 0.1 }
  );
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
