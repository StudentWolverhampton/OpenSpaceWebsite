<section class="border-t border-border px-6 py-20">
  <div class="mx-auto max-w-5xl">
    <div class="grid grid-cols-2 gap-px bg-border md:grid-cols-4">
      <div class="reveal bg-deep py-12 text-center">
        <div class="mb-1 font-display text-4xl font-bold text-gradient-cyber sm:text-5xl">12+</div>
        <div class="text-xs text-subtle sm:text-sm">Shortcuts</div>
      </div>
      <div class="reveal bg-deep py-12 text-center">
        <div class="mb-1 font-display text-4xl font-bold text-foreground sm:text-5xl">8</div>
        <div class="text-xs text-subtle sm:text-sm">Max Terminals</div>
      </div>
      <div class="reveal bg-deep py-12 text-center">
        <div class="mb-1 font-display text-4xl font-bold text-gradient-cyber sm:text-5xl">3</div>
        <div class="text-xs text-subtle sm:text-sm">Terminal Types</div>
      </div>
      <div class="reveal bg-deep py-12 text-center">
        <div class="mb-1 font-display text-4xl font-bold text-foreground sm:text-5xl">Free</div>
        <div class="text-xs text-subtle sm:text-sm">Open-Source</div>
      </div>
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => { entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }); },
    { threshold: 0.1 }
  );
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
