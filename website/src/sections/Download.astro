        <div class="mt-5 flex items-center justify-center gap-4 text-xs text-subtle">
          <span>Version 1.0.0</span>
          <span class="h-1 w-1 rounded-full bg-border"></span>
          <span>~60 MB</span>
          <span class="h-1 w-1 rounded-full bg-border"></span>
          <span>Open-Source</span>
        </div>
      </div>
    </div>
