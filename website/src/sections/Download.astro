<section id="download" class="relative border-t border-border px-6 py-24 sm:py-32">
  <div class="absolute inset-0 bg-gradient-to-b from-ember/2 via-transparent to-transparent"></div>
  <div class="absolute left-0 bottom-0 h-[1px] w-full bg-gradient-to-r from-transparent via-ember/20 to-transparent"></div>

  <div class="relative z-10 mx-auto max-w-4xl">
    <div class="reveal mx-auto mb-16 max-w-2xl text-center">
      <span class="mb-4 inline-block text-xs font-semibold uppercase tracking-[0.2em] text-ember">Download</span>
      <h2 class="mb-4 text-3xl font-bold tracking-tight font-display sm:text-4xl md:text-5xl">
