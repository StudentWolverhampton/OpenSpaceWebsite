            </div>
          </div>
          <span class="rounded-md border border-border bg-dark px-3 py-1 font-mono text-xs text-muted">v1.0.0</span>
        </div>

        <a
          href="https://github.com/StudentWolverhampton/OpenSpaceWebsite/releases/latest/download/OpenSpace-Setup-1.0.0.exe"
          class="group relative flex w-full items-center justify-center gap-3 overflow-hidden rounded-xl bg-ember px-6 py-4 text-base font-semibold text-deep transition-all hover:bg-ember-dark hover:shadow-[0_0_30px_rgba(251,109,58,0.25)] hover:scale-[1.02] active:scale-[0.98]"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
