<style>
  #navbar.scrolled {
    background: rgba(12, 12, 15, 0.75);
    backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }
  #navbar.scrolled .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--color-ember);
    transition: width 0.3s ease;
  }
  #navbar.scrolled .nav-link:hover::after { width: 100%; }
  #mobile-menu.open { display: flex; animation: fade-in 0.3s ease-out; }
  #menu-toggle.open .menu-bar:nth-child(1) { transform: translateY(0) rotate(45deg) !important; }
  #menu-toggle.open .menu-bar:nth-child(2) { opacity: 0; }
  #menu-toggle.open .menu-bar:nth-child(3) { transform: translateY(0) rotate(-45deg) !important; }
  @keyframes fade-in { from { opacity: 0; } to { opacity: 1; } }
</style>

<script>
  const navbar = document.getElementById('navbar');
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        navbar.classList.toggle('scrolled', window.scrollY > 50);
        ticking = false;
      });
      ticking = true;
    }
  });
  if (menuToggle && mobileMenu) {
    menuToggle.addEventListener('click', () => {
      const open = mobileMenu.classList.toggle('open');
      menuToggle.classList.toggle('open', open);
    });
    mobileMenu.querySelectorAll('[data-close]').forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.classList.remove('open');
        menuToggle.classList.remove('open');
      });
    });
  }
</script>
