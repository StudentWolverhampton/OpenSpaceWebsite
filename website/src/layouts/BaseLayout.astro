---
interface Props {
  title?: string;
  description?: string;
}

const { title = 'OpenSpace — Terminal Workspace', description = 'A premium terminal workspace for developers. Multiple terminals, built-in browser, keyboard-first workflow. Free and open-source.' } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://openspace.dev/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://openspace.dev/images/icon.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://openspace.dev/images/icon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href="/images/icon.png" />

    <style>
      @import "tailwindcss";

      @theme {
        --font-serif: 'Playfair Display', serif;
        --font-sans: 'Outfit', sans-serif;
        --font-mono: 'JetBrains Mono', monospace;

        --color-night: #0c0c0f;
        --color-void: #0a0a0d;
        --color-surface: #14141a;
        --color-card: #1a1a22;
        --color-card-hover: #1e1e28;
        --color-ember: #f59e0b;
        --color-ember-dark: #b45309;
        --color-ember-light: #fbbf24;
        --color-gold: #fef3c7;
        --color-foreground: #e8e4de;
        --color-muted: #8a7f74;
        --color-subtle: #4a443e;
        --color-border: rgba(255, 255, 255, 0.06);
        --color-border-hover: rgba(245, 158, 11, 0.2);
      }

      * { scrollbar-width: thin; scrollbar-color: var(--color-subtle) transparent; }
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: var(--color-subtle); border-radius: 3px; }

      body {
        background: var(--color-void);
        color: var(--color-foreground);
        font-family: var(--font-sans);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        overflow-x: hidden;
      }

      ::selection { background: rgba(245, 158, 11, 0.25); color: #fff; }

      .glow-amber {
        box-shadow: 0 0 50px rgba(245, 158, 11, 0.06), 0 0 100px rgba(245, 158, 11, 0.03);
      }
      .glow-amber-strong {
        box-shadow: 0 0 60px rgba(245, 158, 11, 0.1), 0 0 120px rgba(245, 158, 11, 0.05);
      }

      .text-ember-gradient {
        background: linear-gradient(135deg, var(--color-ember-light), var(--color-ember), var(--color-ember-dark));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .card-glass {
        background: linear-gradient(165deg, rgba(26, 26, 34, 0.6), rgba(20, 20, 26, 0.8));
        backdrop-filter: blur(12px);
        border: 1px solid var(--color-border);
        transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .card-glass:hover {
        border-color: var(--color-border-hover);
        background: linear-gradient(165deg, rgba(30, 30, 40, 0.7), rgba(20, 20, 26, 0.9));
        box-shadow: 0 0 40px rgba(245, 158, 11, 0.04), inset 0 1px 0 rgba(245, 158, 11, 0.08);
        transform: translateY(-2px);
      }

      .btn-primary {
        position: relative;
        background: linear-gradient(135deg, var(--color-ember), var(--color-ember-dark));
        color: var(--color-night);
        font-weight: 600;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        overflow: hidden;
      }
      .btn-primary::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, var(--color-ember-light), var(--color-ember));
        opacity: 0;
        transition: opacity 0.4s ease;
      }
      .btn-primary:hover::before { opacity: 1; }
      .btn-primary:hover {
        box-shadow: 0 0 40px rgba(245, 158, 11, 0.25), 0 0 80px rgba(245, 158, 11, 0.1);
        transform: translateY(-1px);
      }
      .btn-primary:active { transform: translateY(0) scale(0.98); }
      .btn-primary span { position: relative; z-index: 1; }

      .btn-ghost {
        border: 1px solid var(--color-border);
        background: rgba(255, 255, 255, 0.02);
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .btn-ghost:hover {
        border-color: var(--color-border-hover);
        background: rgba(245, 158, 11, 0.04);
        box-shadow: inset 0 1px 0 rgba(245, 158, 11, 0.06);
      }

      .reveal {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .reveal.visible { opacity: 1; transform: translateY(0); }
      .reveal-scale {
        opacity: 0;
        transform: scale(0.95);
        transition: opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1), transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .reveal-scale.visible { opacity: 1; transform: scale(1); }

      @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
      @keyframes pulse-amber { 0%, 100% { opacity: 0.3; } 50% { opacity: 0.7; } }
      @keyframes drift-slow {
        0% { transform: translate(0, 0) scale(1); }
        50% { transform: translate(40px, -20px) scale(1.05); }
        100% { transform: translate(0, 0) scale(1); }
      }
      @keyframes fade-in-up {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
      }

      .animate-float { animation: float 6s ease-in-out infinite; }
      .animate-pulse-amber { animation: pulse-amber 4s ease-in-out infinite; }
      .animate-drift-slow { animation: drift-slow 15s ease-in-out infinite; }
      .animate-fade-in-up { animation: fade-in-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; }

      .stagger-1 { animation-delay: 0.1s; }
      .stagger-2 { animation-delay: 0.2s; }
      .stagger-3 { animation-delay: 0.35s; }
      .stagger-4 { animation-delay: 0.5s; }
      .stagger-5 { animation-delay: 0.65s; }

      .stagger-sm-1 { transition-delay: 0.05s; }
      .stagger-sm-2 { transition-delay: 0.1s; }
      .stagger-sm-3 { transition-delay: 0.15s; }
      .stagger-sm-4 { transition-delay: 0.2s; }

      .noise-overlay {
        position: fixed;
        inset: 0;
        z-index: 9999;
        pointer-events: none;
        opacity: 0.02;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        background-size: 128px 128px;
      }

      .orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(100px);
        pointer-events: none;
      }

      @media (prefers-reduced-motion) {
        .animate-float, .animate-drift-slow, .animate-pulse-amber,
        .reveal, .reveal-scale, .animate-fade-in-up {
          animation: none !important;
          opacity: 1 !important;
          transform: none !important;
          transition: none !important;
        }
      }
    </style>
  </head>
  <body class="bg-void text-foreground antialiased">
    <div class="noise-overlay"></div>
    <slot />
  </body>
</html>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) e.target.classList.add('visible');
      });
    },
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
  );
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.reveal, .reveal-scale').forEach((el) => observer.observe(el));
  });
</script>
